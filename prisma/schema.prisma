datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @default(uuid())
  clerkId         String    @unique
  email           String
  plan            String    @default("Free") // "Free" or "Pro" or "Team"
  generationsUsed Int       @default(0)
  createdAt       DateTime  @default(now())
  projects        Project[]
}

model Project {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  thumbnail String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  versions  Version[]
}

model Version {
  id             String          @id @default(uuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sketchUrl      String          // stores base64 PNG data or url
  generatedCode  String
  stylePrompt    String
  createdAt      DateTime        @default(now())
  sharedPreviews SharedPreview[]
}

model SharedPreview {
  id        String   @id @default(uuid())
  versionId String
  version   Version  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  slug      String   @unique
  expiresAt DateTime?
  views     Int      @default(0)
  createdAt DateTime @default(now())
}
